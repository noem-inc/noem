{
  "name": "@noem/platform-keystore",
  "version": "0.0.0",
  "description": "Initial Commit Platform Keystore",
  "keywords": [],
  "homepage": "https://github.com/noem-inc/noem/tree/main/packages/platform-keystore#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noem-inc/noem.git",
    "directory": "packages/platform-keystore"
  },
  "bugs": {
    "url": "https://github.com/noem-inc/noem/issues"
  },
  "author": {
    "name": "Noem Inc.",
    "url": "https://www.noem.io/"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "napi": {
    "binaryName": "platform-keystore",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "aarch64-apple-darwin"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "napi build --platform --release -o dist --js index.cjs --dts index.d.cts && napi build --platform --release --esm -o dist --js index.js --dts index.d.ts",
    "dev": "napi build --platform -o dist --js index.cjs --dts index.d.cts && napi build --platform --esm -o dist --js index.js --dts index.d.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check . && cargo fmt --check && cargo clippy && tsc --noEmit -p tsconfig.json",
    "lint:fix": "biome check --write . && cargo fmt && cargo clippy --fix --allow-dirty"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@napi-rs/cli": "catalog:",
    "@types/node": "^25.9.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  }
}
