{
  "name": "@noem/encryption",
  "version": "0.0.4",
  "description": "Isomorphic field-level encryption helper using WebCrypto AES-256-GCM with authenticated envelopes and key rotation.",
  "keywords": [
    "encryption",
    "field-level-encryption",
    "envelope-encryption",
    "aes",
    "aes-gcm",
    "aes-256-gcm",
    "webcrypto",
    "crypto",
    "key-rotation",
    "pii",
    "isomorphic",
    "edge",
    "esm",
    "cjs",
    "typescript",
    "node",
    "browser"
  ],
  "homepage": "https://github.com/noem-inc/noem/tree/main/packages/encryption#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noem-inc/noem.git",
    "directory": "packages/encryption"
  },
  "bugs": {
    "url": "https://github.com/noem-inc/noem/issues"
  },
  "author": {
    "name": "Noem Inc.",
    "url": "https://www.noem.io/"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check . && tsc --noEmit -p tsconfig.json",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist .turbo"
  },
  "license": "MIT",
  "dependencies": {
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  }
}
