{
  "name": "noem",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/sync-all-versions.mts",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "spellcheck": "cspell lint .",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "changeset": "changeset",
    "version": "changeset version && node scripts/sync-all-versions.mts",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "clean": "find . -type d \\( -name node_modules -o -name .turbo -o -name coverage -o -name target \\) -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/cli": "^2.29.7",
    "@types/node": "^25.9.3",
    "cspell": "^10.0.1",
    "smol-toml": "^1.6.1",
    "turbo": "^2.9.18",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=18"
  }
}
