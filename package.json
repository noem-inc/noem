{
  "name": "noem",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "changeset": "changeset",
    "version": "changeset version && node scripts/sync-cargo-version.mjs",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "clean": "find . -type d \\( -name node_modules -o -name .turbo -o -name coverage \\) -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/cli": "^2.29.7",
    "turbo": "^2.9.14",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=18"
  }
}
