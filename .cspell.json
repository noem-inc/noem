{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "ignoreRandomStrings": true,
  "useGitignore": true,
  "words": [
    "noem",
    "smol",
    "luhn",
    "rustup",
    "msvc",
    "winget",
    "serde",
    "clippy",
    "mtsx",
    "ciphertext",
    "zeroize",
    "ncrypt",
    "libuv",
    "threadpool",
    "oaep",
    "ecies",
    "subpackages",
    "picklist",
    "algs",
    "nvmrc",
    "dtolnay",
    "taiki",
    "repr",
    "napi"
  ],
  "ignorePaths": [
    "*.rs",
    "*.toml",
    "**package.json",
    "**test**",
    "pnpm-workspace.yaml",
    "**pnpm-lock.yaml",
    "**.lock"
  ]
}
